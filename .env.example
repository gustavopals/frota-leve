# =============================================================================
# FROTA LEVE — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com os valores reais
# NUNCA commite o arquivo .env com valores reais
# =============================================================================

# -----------------------------------------------------------------------------
# APLICAÇÃO
# -----------------------------------------------------------------------------
NODE_ENV=development            # development | production | test
PORT=3000                       # Porta da API

# -----------------------------------------------------------------------------
# BANCO DE DADOS (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/frota_leve_dev?schema=public"

# -----------------------------------------------------------------------------
# REDIS (Cache, filas, sessões)
# -----------------------------------------------------------------------------
REDIS_URL="redis://localhost:6379"

# -----------------------------------------------------------------------------
# AUTENTICAÇÃO JWT
# -----------------------------------------------------------------------------
JWT_SECRET="troque-por-uma-chave-secreta-forte-de-pelo-menos-32-caracteres"
JWT_REFRESH_SECRET="troque-por-outra-chave-secreta-forte-de-pelo-menos-32-caracteres"
JWT_EXPIRES_IN="15m"            # Expiração do access token
JWT_REFRESH_EXPIRES_IN="7d"     # Expiração do refresh token

# -----------------------------------------------------------------------------
# INTELIGÊNCIA ARTIFICIAL (Claude API - Anthropic)
# Obtenha em: https://console.anthropic.com
# -----------------------------------------------------------------------------
CLAUDE_API_KEY="sk-ant-..."

# -----------------------------------------------------------------------------
# PAGAMENTOS (Stripe)
# Obtenha em: https://dashboard.stripe.com/apikeys
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_ESSENTIAL="price_..."    # ID do price do Plano Essencial
STRIPE_PRICE_PROFESSIONAL="price_..." # ID do price do Plano Profissional

# -----------------------------------------------------------------------------
# ARMAZENAMENTO DE ARQUIVOS (AWS S3)
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID="AKIA..."
AWS_SECRET_ACCESS_KEY="..."
AWS_S3_BUCKET="frota-leve-uploads"
AWS_REGION="us-east-1"
AWS_CLOUDFRONT_URL=""           # URL do CloudFront CDN (opcional)

# -----------------------------------------------------------------------------
# E-MAIL (Resend)
# Obtenha em: https://resend.com
# -----------------------------------------------------------------------------
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@frotaleve.com.br"
EMAIL_FROM_NAME="Frota Leve"

# -----------------------------------------------------------------------------
# FRONTEND
# -----------------------------------------------------------------------------
FRONTEND_URL="http://localhost:4200"  # URL do frontend (para links em e-mails, CORS)

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
LOG_LEVEL="debug"              # error | warn | info | debug

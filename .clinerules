## 🔶 Frontend (Angular)

### 1. Components

**SEMPRE:**
```typescript
@Component({
  selector: 'app-resource-list',
  standalone: true,                          // ✅ Standalone
  imports: [CommonModule, RouterLink],       // ✅ Imports explícitos
  templateUrl: './resource-list.html',
  styleUrl: './resource-list.scss'
})
export class ResourceListComponent implements OnInit {
  // Signals para estado reativo
  items = signal<Resource[]>([]);
  loading = signal(false);
  error = signal<string | null>(null);

  constructor(private service: ResourceService) {}

  async ngOnInit() {
    await this.loadItems();
  }

  async loadItems() {
    this.loading.set(true);
    this.error.set(null);

    try {
      const data = await this.service.getAll();
      this.items.set(data);
    } catch (err: any) {
      this.error.set('Erro ao carregar dados');  // ✅ Português
      console.error(err);
    } finally {
      this.loading.set(false);
    }
  }
}
```

**NUNCA:**
```typescript
// ❌ Não standalone
@Component({
  selector: 'app-resource-list',
  standalone: false  // Não usar modules antigos
})

// ❌ Variáveis normais ao invés de signals
items: Resource[] = [];
loading = false;

// ❌ Subscribe ao invés de async/await
this.service.getAll().subscribe(data => this.items = data);

// ❌ Mensagem em inglês
this.error.set('Error loading data');
```

---

### 2. Services

**SEMPRE:**
```typescript
@Injectable({ providedIn: 'root' })
export class ResourceService {
  private api = inject(ApiService);

  getAll(filters?: { status?: string }) {
    return this.api.get<Resource[]>('/resources', filters);
  }

  getById(id: string) {
    return this.api.get<Resource>(`/resources/${id}`);
  }

  create(data: Partial<Resource>) {
    return this.api.post<Resource>('/resources', data);
  }

  update(id: string, data: Partial<Resource>) {
    return this.api.patch<Resource>(`/resources/${id}`, data);
  }

  delete(id: string) {
    return this.api.delete<void>(`/resources/${id}`);
  }
}
```

**NUNCA:**
```typescript
// ❌ Sem providedIn: 'root'
@Injectable()
export class ResourceService {}

// ❌ Sem tipagem genérica
getAll() {
  return this.api.get('/resources');  // Retorna any
}

// ❌ HttpClient direto (usar ApiService)
constructor(private http: HttpClient) {}
getAll() {
  return this.http.get('http://localhost:3000/resources');
}
```

---

### 3. Forms (Reactive)

**SEMPRE:**
```typescript
form!: FormGroup;

ngOnInit() {
  this.form = this.fb.group({
    name: ['', [Validators.required, Validators.minLength(3)]],
    email: ['', [Validators.required, Validators.email]],
    status: ['', Validators.required]
  });
}

async onSubmit() {
  if (this.form.invalid) {
    this.form.markAllAsTouched();  // ✅ Mostra erros
    return;
  }

  this.loading.set(true);

  try {
    await this.service.create(this.form.value);
    this.router.navigate(['/resources']);
  } catch (error: any) {
    alert(error.error?.message || 'Erro ao salvar');
  } finally {
    this.loading.set(false);
  }
}
```

**Template:**
```html
<input 
  formControlName="name"
  class="w-full px-4 py-2 bg-input border border-border rounded-lg"
  [class.border-red-500]="form.get('name')?.invalid && form.get('name')?.touched"
/>
@if (form.get('name')?.hasError('required') && form.get('name')?.touched) {
  <p class="text-red-500 text-sm mt-1">Nome é obrigatório</p>
}
```

**NUNCA:**
```typescript
// ❌ Template-driven forms
<input [(ngModel)]="name" />

// ❌ Sem markAllAsTouched antes de validar
if (this.form.invalid) {
  return;  // Usuário não vê onde está errado
}

// ❌ Classes hard-coded
class="border-gray-300"  // Usar border-border
class="bg-white"         // Usar bg-card
```

---

### 4. Templates (HTML)

**SEMPRE:**
```html
<!-- ✅ Classes semânticas do design system -->
<div class="bg-card border border-border rounded-lg p-6">
  <h2 class="text-xl font-bold text-foreground mb-4">Título</h2>
  <p class="text-muted-foreground">Descrição</p>
</div>

<!-- ✅ Control flow syntax (@if, @for) -->
@if (loading()) {
  <p>Carregando...</p>
}

@for (item of items(); track item.id) {
  <div>{{ item.name }}</div>
}

<!-- ✅ Pipes para formatação -->
{{ date | date: 'dd/MM/yyyy' }}
{{ value | currency: 'BRL' }}
```

**NUNCA:**
```html
<!-- ❌ Classes hard-coded -->
<div class="bg-gray-800 border-gray-700 text-white">

<!-- ❌ Syntax antiga -->
<div *ngIf="loading">
<div *ngFor="let item of items">

<!-- ❌ Formatação manual -->
{{ date.split('T')[0] }}  <!-- Usar pipe -->
```


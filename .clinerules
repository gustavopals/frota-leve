## 🧪 Testes (TODO - Implementar)

### Backend (Jest)

**Service Test:**
```typescript
describe('VehiclesService', () => {
  let service: VehiclesService;
  let prisma: PrismaService;

  beforeEach(async () => {
    const module = await Test.createTestingModule({
      providers: [VehiclesService, PrismaService]
    }).compile();

    service = module.get(VehiclesService);
    prisma = module.get(PrismaService);
  });

  it('deve criar veículo com tenantId correto', async () => {
    const tenantId = 'tenant-123';
    const dto = { name: 'Fiorino', plate: 'ABC1D23' };

    const result = await service.create(tenantId, dto);

    expect(result.tenantId).toBe(tenantId);
    expect(result.name).toBe('Fiorino');
  });

  it('deve bloquear acesso a veículo de outro tenant', async () => {
    await expect(
      service.findOne('tenant-wrong', 'vehicle-id')
    ).rejects.toThrow(NotFoundException);
  });
});
```

### Frontend (Jasmine)

**Component Test:**
```typescript
describe('VehicleListComponent', () => {
  let component: VehicleListComponent;
  let service: VehicleService;

  beforeEach(async () => {
    await TestBed.configureTestingModule({
      imports: [VehicleListComponent]
    }).compileComponents();

    component = TestBed.createComponent(VehicleListComponent).componentInstance;
    service = TestBed.inject(VehicleService);
  });

  it('deve carregar veículos no init', async () => {
    spyOn(service, 'getAll').and.returnValue(Promise.resolve([
      { id: '1', name: 'Fiorino' }
    ]));

    await component.ngOnInit();

    expect(component.vehicles().length).toBe(1);
  });
});
```


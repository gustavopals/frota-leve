generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  document  String?  @db.VarChar(50)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                User[]
  vehicles             Vehicle[]
  maintenancePlans     MaintenancePlan[]
  maintenances         Maintenance[]
  fuelLogs             FuelLog[]
  checklistTemplates   ChecklistTemplate[]
  checklistSubmissions ChecklistSubmission[]
  reminders            Reminder[]
  settings             TenantSettings?

  @@index([document])
  @@map("tenants")
}

enum UserRole {
  ADMIN_EMPRESA
  GESTOR_FROTA
  MOTORISTA
}

model User {
  id           String   @id @default(uuid())
  tenantId     String
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant               Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fuelLogs             FuelLog[]
  checklistSubmissions ChecklistSubmission[]
  settings             UserSettings?

  @@index([tenantId])
  @@index([email])
  @@map("users")
}

enum VehicleStatus {
  ACTIVE
  MAINTENANCE
  SOLD
  INACTIVE
}

model Vehicle {
  id              String        @id @default(uuid())
  tenantId        String
  name            String
  plate           String
  renavam         String?
  type            String?
  brand           String?
  model           String?
  year            Int?
  currentOdometer Decimal       @default(0) @db.Decimal(10, 2)
  status          VehicleStatus @default(ACTIVE)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  tenant               Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  maintenances         Maintenance[]
  fuelLogs             FuelLog[]
  checklistSubmissions ChecklistSubmission[]
  reminders            Reminder[]

  @@index([tenantId])
  @@index([plate])
  @@map("vehicles")
}

model MaintenancePlan {
  id           String   @id @default(uuid())
  tenantId     String
  vehicleType  String?
  name         String
  description  String?  @db.Text
  intervalKm   Decimal? @db.Decimal(10, 2)
  intervalDays Int?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  maintenances Maintenance[]

  @@index([tenantId])
  @@map("maintenance_plans")
}

model Maintenance {
  id                String   @id @default(uuid())
  tenantId          String
  vehicleId         String
  maintenancePlanId String?
  date              DateTime @db.Date
  odometer          Decimal? @db.Decimal(10, 2)
  cost              Decimal? @db.Decimal(12, 2)
  provider          String?
  notes             String?  @db.Text
  createdAt         DateTime @default(now())

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vehicle         Vehicle          @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  maintenancePlan MaintenancePlan? @relation(fields: [maintenancePlanId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([vehicleId])
  @@index([date])
  @@map("maintenances")
}

model FuelLog {
  id         String   @id @default(uuid())
  tenantId   String
  vehicleId  String
  driverId   String?
  date       DateTime @db.Date
  station    String?
  liters     Decimal  @db.Decimal(10, 2)
  totalValue Decimal  @db.Decimal(12, 2)
  odometer   Decimal  @db.Decimal(10, 2)
  createdAt  DateTime @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  driver  User?   @relation(fields: [driverId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([vehicleId])
  @@index([date])
  @@map("fuel_logs")
}

model ChecklistTemplate {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  vehicleType String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  tenant               Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items                ChecklistTemplateItem[]
  checklistSubmissions ChecklistSubmission[]

  @@index([tenantId])
  @@map("checklist_templates")
}

enum ChecklistItemType {
  BOOLEAN
  TEXT
  NUMBER
  SELECT
}

model ChecklistTemplateItem {
  id         String            @id @default(uuid())
  templateId String
  label      String
  type       ChecklistItemType
  config     Json?
  sortOrder  Int               @default(0)

  template ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  answers  ChecklistAnswer[]

  @@index([templateId])
  @@map("checklist_template_items")
}

enum ChecklistStatus {
  OK
  ALERT
  CRITICAL
}

model ChecklistSubmission {
  id            String          @id @default(uuid())
  tenantId      String
  templateId    String
  vehicleId     String
  driverId      String
  submittedAt   DateTime        @default(now())
  overallStatus ChecklistStatus @default(OK)

  tenant   Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  template ChecklistTemplate   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  vehicle  Vehicle             @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  driver   User                @relation(fields: [driverId], references: [id], onDelete: Cascade)
  answers  ChecklistAnswer[]

  @@index([tenantId])
  @@index([vehicleId])
  @@index([driverId])
  @@index([submittedAt])
  @@map("checklist_submissions")
}

model ChecklistAnswer {
  id             String  @id @default(uuid())
  submissionId   String
  templateItemId String
  value          String  @db.Text

  submission   ChecklistSubmission   @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  templateItem ChecklistTemplateItem @relation(fields: [templateItemId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@map("checklist_answers")
}

enum ReminderType {
  IPVA
  LICENCIAMENTO
  INSURANCE
  MAINTENANCE
  CUSTOM
}

enum ReminderStatus {
  PENDING
  SENT
  DONE
  DISMISSED
}

model Reminder {
  id          String         @id @default(uuid())
  tenantId    String
  vehicleId   String?
  type        ReminderType
  title       String
  description String?        @db.Text
  dueDate     DateTime?      @db.Date
  dueOdometer Decimal?       @db.Decimal(10, 2)
  status      ReminderStatus @default(PENDING)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vehicle Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([vehicleId])
  @@index([dueDate])
  @@index([status])
  @@map("reminders")
}

model TenantSettings {
  tenantId    String @id
  preferences Json   @default("{}")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_settings")
}

model UserSettings {
  userId      String @id
  preferences Json   @default("{}")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

# =============================================================================
# FROTA LEVE — Coolify / Docker Compose Stack
# Cadastre estas variáveis no painel do Coolify ou copie para um .env local
# =============================================================================

# Porta exposta do PostgreSQL no host da VPS
POSTGRES_PORT=5433

# Banco de dados
POSTGRES_DB=frota_leve
POSTGRES_USER=postgres
POSTGRES_PASSWORD=troque-por-uma-senha-forte

# Autenticação
JWT_SECRET=troque-por-uma-chave-secreta-forte-de-pelo-menos-32-caracteres
JWT_REFRESH_SECRET=troque-por-outra-chave-secreta-forte-de-pelo-menos-32-caracteres
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Frontend / CORS
FRONTEND_URL=https://app.seudominio.com

# Logging
LOG_LEVEL=info

# Integrações opcionais
CLAUDE_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ESSENTIAL=
STRIPE_PRICE_PROFESSIONAL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1
AWS_CLOUDFRONT_URL=
RESEND_API_KEY=
EMAIL_FROM=noreply@frotaleve.com.br
EMAIL_FROM_NAME=Frota Leve

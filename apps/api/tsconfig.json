{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "outDir": "./dist",
    "rootDir": "./src",
    "paths": {
      "@frota-leve/shared": ["../../packages/shared"],
      "@frota-leve/shared/*": ["../../packages/shared/*"],
      "@frota-leve/database": ["../../packages/database"],
      "@frota-leve/database/*": ["../../packages/database/*"],
      "@frota-leve/ai": ["../../packages/ai"],
      "@frota-leve/ai/*": ["../../packages/ai/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts"],
  "exclude": ["node_modules", "dist", "coverage"]
}

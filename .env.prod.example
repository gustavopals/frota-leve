# =============================================================================
# FROTA LEVE — Produção via Docker Compose
# Copie este arquivo para .env.prod no servidor e preencha os valores reais
# =============================================================================

# Imagens publicadas pelo workflow de deploy
API_IMAGE=docker.io/seu-usuario/frota-leve-api:latest
WEB_IMAGE=docker.io/seu-usuario/frota-leve-web:latest

# Portas públicas
WEB_PORT=80

# Banco de dados
POSTGRES_DB=frota_leve
POSTGRES_USER=postgres
POSTGRES_PASSWORD=troque-por-uma-senha-forte

# Autenticação
JWT_SECRET=troque-por-uma-chave-secreta-forte-de-pelo-menos-32-caracteres
JWT_REFRESH_SECRET=troque-por-outra-chave-secreta-forte-de-pelo-menos-32-caracteres
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Frontend / CORS
FRONTEND_URL=https://app.seudominio.com

# Logging
LOG_LEVEL=info

# Integrações opcionais
CLAUDE_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ESSENTIAL=
STRIPE_PRICE_PROFESSIONAL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1
AWS_CLOUDFRONT_URL=
RESEND_API_KEY=
EMAIL_FROM=noreply@frotaleve.com.br
EMAIL_FROM_NAME=Frota Leve
